{%- comment -%} Kalles Integration Assets {%- endcomment -%}

<!-- Kalles Integration Styles -->
<link rel="stylesheet" href="{{ 'kalles-theme.css' | asset_url }}">
<link rel="stylesheet" href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css">
{{ 'kalles-base.css' | asset_url | stylesheet_tag }}

<!-- Kalles Lazyload Polyfill for Freyeri -->
<script>
document.addEventListener("DOMContentLoaded", function() {
    const processKallesLazyLoad = () => {
        document.querySelectorAll('.lazyloadt4s, .t4s-has-imgbg').forEach(function(el) {
            if (el.tagName === 'IMG' && el.dataset.src) {
                // Replace width=1 with a reasonable size for native loading
                let newSrc = el.dataset.src.replace('width=1', 'width=800');
                el.src = newSrc;
                el.setAttribute('loading', 'lazy');
            } else if (el.dataset.bgset) {
                let newBg = el.dataset.bgset.replace('width=1', 'width=800');
                el.style.backgroundImage = 'url(' + newBg + ')';
            }
            
            // Fix inline backgrounds that were set to width=1
            if (el.style.backgroundImage && el.style.backgroundImage.includes('width=1')) {
                el.style.backgroundImage = el.style.backgroundImage.replace('width=1', 'width=800');
            }

            el.classList.remove('lazyloadt4s');
            el.classList.add('lazyloadt4sed'); 
        });
    };
    processKallesLazyLoad();
    document.addEventListener('shopify:section:load', processKallesLazyLoad);
    document.addEventListener('shopify:block:select', processKallesLazyLoad);
    document.addEventListener('shopify:block:deselect', processKallesLazyLoad);
    setInterval(processKallesLazyLoad, 1000); // Catch dynamic editor changes
});
</script>

<script>
  window.T4Sconfigs = {
    theme: 'kalles',
    is_rtl: false,
    money_format: {{ shop.money_format | json }},
    settings: {
      enable_lazyload: true,
      time_slider: 5000,
      product_grid_ratio: "1",
      product_grid_crop: "center"
    }
  };
</script>

<!-- Fix Kalles animations being stuck on hidden without global JS -->
<style>
  [hdt-reveal]:not([animationend]) {
      opacity: 1 !important;
      visibility: visible !important;
      transform: none !important;
  }
</style>

<script src="{{ 'flickity.pkgd.min.js' | asset_url }}" defer="defer"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    const initFlickity = () => {
        if (typeof Flickity !== 'undefined') {
            document.querySelectorAll('.flickityt4s:not(.flickity-enabled)').forEach(function(el) {
                try {
                    let optionsStr = el.getAttribute('data-flickityt4s-js') || '{}';
                    let options = JSON.parse(optionsStr);
                    // Convert custom kalles options to standard if needed
                    options.lazyLoad = false; // Handled by our image polyfill
                    if (options.wrapAround === undefined) options.wrapAround = true;
                    if (options.pageDots === undefined) options.pageDots = true;
                    
                    let flkty = new Flickity(el, options);
                    
                    // Inject Kalles-specific classes so the Kalles grid CSS applies properly
                    el.classList.add('flickityt4s-enabled'); 
                    
                    let viewport = el.querySelector('.flickity-viewport');
                    if (viewport) viewport.classList.add('flickityt4s-viewport');
                    
                    let slider = el.querySelector('.flickity-slider');
                    if (slider) slider.classList.add('flickityt4s-slider');
                    
                    let dots = el.querySelector('.flickity-page-dots');
                    if (dots) dots.classList.add('flickityt4s-page-dots');
                    
                    el.querySelectorAll('.flickity-button').forEach(b => {
                        b.classList.add('flickityt4s-button');
                        if (b.classList.contains('previous')) b.classList.add('flickityt4s-prev-next-button');
                        if (b.classList.contains('next')) b.classList.add('flickityt4s-prev-next-button');
                    });
                    
                    // Trigger resize to fix layout after classes are added
                    setTimeout(() => flkty.resize(), 100);
                } catch(e) {
                    console.error('Error initializing Flickity for Kalles section:', e);
                }
            });
        }
    };
    
    // Init after a short delay to ensure Flickity is loaded
    setTimeout(initFlickity, 500);
    document.addEventListener('shopify:section:load', () => setTimeout(initFlickity, 200));
    document.addEventListener('shopify:block:select', () => setTimeout(initFlickity, 200));
    setInterval(initFlickity, 1500);
});
</script>

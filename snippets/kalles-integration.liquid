{% comment %} 
  KALLES INTEGRATION SNIPPET
  This snippet safely loads necessary CSS variables, scripts, and stylesheets 
  from the Kalles theme to ensure Kalles sections work in the Freyeri theme.
{% endcomment %}

<style>
  :root {
      --wrapper-mw: 1200px;
      --t4s-success-color: #428445;
      --t4s-warning-color: #e0b252;
      --t4s-error-color: #EB001B;
      --t4s-light-color: #ffffff;
      --t4s-dark-color: #222222;
      --t4s-highlight-color: #ec0101;
      --t4s-tooltip-background: #000;
      --t4s-tooltip-color: #fff;
      --primary-sw-color: #000;
      --border-sw-color: #ddd;
      --secondary-sw-color: #fff;
      --primary-price-color: #ec0101;
      --secondary-price-color: #878787;
      --t4s-body-background: #ffffff;
      --text-color: #878787;
      --heading-color: #222222;
      --accent-color: #56cfe1;
      --secondary-color: #222222;
      --link-color: #878787;
      --link-color-hover: #56cfe1;
      --border-color: #e5e5e5;
      --border-primary-color: #222222;
      --button-background: #222222;
      --button-color: #ffffff;
      --button-background-hover: #56cfe1;
      --button-color-hover: #ffffff;
      --sale-badge-background: #56cfe1;
      --sale-badge-color: #ffffff;
      --new-badge-background: #008ee2;
      --new-badge-color: #ffffff;
  }
</style>

{%- comment -%} 
  We load the kalles-theme.css asynchronously to prevent blocking render,
  and avoid kalles-base.css to prevent global CSS resets from breaking Freyeri.
{%- endcomment -%}
<link rel="stylesheet" href="{{ 'kalles-base.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'kalles-theme.css' | asset_url }}" media="print" onload="this.media='all'">
{%- if settings.kalles_custom_css != blank -%}
  <link rel="stylesheet" href="{{ 'kalles-custom.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<script>
  window.T4Srequest = {
    design_mode: {{ request.design_mode | default: false }},
    page_type: '{{ request.page_type }}',
    path: {{ request.path | json }}
  };
  window.T4Sroutes = {
    root_url: '{{ routes.root_url }}',
    search_url: '{{ routes.search_url }}',
    predictive_search_url: '{{ routes.predictive_search_url }}',
    all_url: '{{ routes.all_products_collection_url }}',
    cart_url: '{{ routes.cart_url }}',
    cart_add_url: '{{ routes.cart_add_url }}',
    cart_change_url: '{{ routes.cart_change_url }}',
    cart_update_url: '{{ routes.cart_update_url }}'
  };
  window.T4sFunc = {
    psjson_lib: new Array
  };
  window.T4SProductStrings = {};
  window.T4Sstrings = {};
  window.T4Sconfigs = {
    theme: 'kalles',
    moneyFormat: {{ shop.money_format | json }},
    moneyWithCurrencyFormat: {{ shop.money_with_currency_format | json }},
    script1: '{{ 'kalles-polyfill.min.js' | asset_url }}',
    script2: '{{ 'kalles-theme.min.js' | asset_url }}',
    script3: '{{ 'kalles-interactable.min.js' | asset_url }}',
    script5: '{{ 'kalles-t4s_zoom.min.js' | asset_url }}',
    script6: '{{ 'kalles-predictive-search.min.js' | asset_url }}',
    script7: '{{ 'kalles-facets.min.js' | asset_url }}',
    script8: '{{ 'kalles-nouislider.min.js' | asset_url }}',
    script9: '{{ 'des_adm.min.js' | asset_url }}',
    script10: '{{ 'kalles-t4s-instant-page.min.js' | asset_url }}',
    script11: 'none',
    script12: '{{ 'kalles-reviewOther.js' | asset_url }}',
    script12a: '{{ 'kalles-t4s-currencies.min.js' | asset_url }}',
    script12b: '{{ 'kalles-threesixty.min.js' | asset_url }}',
    stylesheet1: '{{ 'kalles-mini-cart.css' | asset_url }}',
    stylesheet2: '{{ 'kalles-mobile_nav.css' | asset_url }}',
    stylesheet3: '{{ 'kalles-login-sidebar.css' | asset_url }}',
    stylesheet4: '{{ 'kalles-search-hidden.css' | asset_url }}'
  };
</script>

<script src="{{ 'kalles-global.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'kalles-theme.min.js' | asset_url }}" defer="defer"></script>


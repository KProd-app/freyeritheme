    "custom_liquid_pGdAdh": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<section class=\"testimonials-wrap\">\n  <div class=\"testimonials-inner\">\n    <div class=\"testimonials-grid\">\n\n      <div class=\"testimonial-item\">\n        <div class=\"stars\">★★★★★</div>\n        <p class=\"testimonial-text\">\n          The diffuser looks incredibly premium and the scent is subtle but long-lasting. My car finally feels complete.\n        </p>\n        <div class=\"testimonial-author\">\n          — Lukas M., Germany\n        </div>\n      </div>\n\n      <div class=\"testimonial-item\">\n        <div class=\"stars\">★★★★★</div>\n        <p class=\"testimonial-text\">\n          I’ve tried many car fragrances before, but this is on another level. Elegant design and no overpowering smell.\n        </p>\n        <div class=\"testimonial-author\">\n          — Daan R., Netherlands\n        </div>\n      </div>\n\n      <div class=\"testimonial-item\">\n        <div class=\"stars\">★★★★★</div>\n        <p class=\"testimonial-text\">\n          You can really feel the quality. Handmade, stylish, and the scent lasts for weeks. Highly recommended.\n        </p>\n        <div class=\"testimonial-author\">\n          — Emma K., Sweden\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<style>\n/* ===== BASE ===== */\n.testimonials-wrap{\n  padding: 36px 0;\n  background: transparent;\n}\n\n.testimonials-inner{\n  max-width: 1100px;\n  margin: 0 auto;\n  padding: 0 18px;\n}\n\n.testimonials-grid{\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.testimonial-item{\n  background: rgba(255,255,255,0.6);\n  backdrop-filter: blur(6px);\n  -webkit-backdrop-filter: blur(6px);\n  border-radius: 16px;\n  padding: 22px 20px;\n  text-align: center;\n}\n\n/* ⭐ ŽVAIGŽDUTĖS – didesnės + gilesnis auksas */\n.stars{\n  color: #009758; /* deep gold */\n  font-size: 17px;\n  letter-spacing: 2px;\n  margin-bottom: 12px;\n}\n\n/* TEXT – juodas + semi-bold */\n.testimonial-text{\n  font-size: 14px;\n  line-height: 1.5;\n  font-weight: 600; /* semi-bold */\n  color: #000;\n  margin-bottom: 12px;\n}\n\n/* AUTHOR – taip pat juodas + semi-bold */\n.testimonial-author{\n  font-size: 13px;\n  font-weight: 600;\n  color: #000;\n}\n\n/* ===== MOBILE ===== */\n@media (max-width: 749px){\n  .testimonials-wrap{\n    padding: 22px 0;\n  }\n\n  .testimonials-grid{\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n    gap: 12px;\n  }\n\n  /* Slepiam trečią testimonial mobile */\n  .testimonial-item:nth-child(3){\n    display: none;\n  }\n\n  .testimonial-item{\n    padding: 16px 14px;\n  }\n\n  .stars{\n    font-size: 16px;\n  }\n\n  .testimonial-text{\n    font-size: 13px;\n  }\n\n  .testimonial-author{\n    font-size: 12px;\n  }\n}\n</style>",
        "color_scheme": "scheme-1",
        "padding_top": 20,
        "padding_bottom": 20
      }
    },

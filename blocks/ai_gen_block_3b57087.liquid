{% doc %}
  @prompt
    Create a picture section with an image upload field that displays only on a specific collection page. Include settings to upload an image, adjust image size and alignment, and ensure it's responsive on all devices. The section should be easy to customize through the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-picture-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-collection-picture__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-picture__wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    width: 100%;
  }

  .ai-collection-picture__image-container-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    max-width: 100%;
  }

  .ai-collection-picture__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.border_radius }}px;
    object-fit: cover;
  }

  .ai-collection-picture__placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 300px;
  }

  .ai-collection-picture__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-collection-picture__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-picture__image-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-collection-picture-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 0 {{ block.settings.padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<collection-picture-{{ ai_gen_id }}
  class="ai-collection-picture-{{ ai_gen_id }}"
  data-collection-handle="{{ block.settings.target_collection.handle }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-picture__container-{{ ai_gen_id }}">
    <div class="ai-collection-picture__wrapper-{{ ai_gen_id }}">
      <div class="ai-collection-picture__image-container-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-collection-picture__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-collection-picture__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-collection-picture__empty-state-{{ ai_gen_id }}">
              Upload an image to display on the selected collection page
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</collection-picture-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionPicture{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.checkVisibility();
      }

      checkVisibility() {
        const targetHandle = this.dataset.collectionHandle;
        const currentPath = window.location.pathname;
        
        if (!targetHandle) {
          this.style.display = 'block';
          return;
        }

        const isTargetCollection = currentPath.includes('/collections/' + targetHandle);
        
        if (isTargetCollection) {
          this.style.display = 'block';
        } else {
          this.style.display = 'none';
        }
      }
    }

    customElements.define('collection-picture-{{ ai_gen_id }}', CollectionPicture{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection picture",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collection targeting"
    },
    {
      "type": "collection",
      "id": "target_collection",
      "label": "Display on collection",
      "info": "Leave empty to display on all pages"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Desktop width",
      "default": 100
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Collection picture"
    }
  ]
}
{% endschema %}
